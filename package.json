{
  "name": "rend",
  "private": true,
  "version": "1.0.0",
  "description": "Merged Payload + Next + SvelteKit project",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:next": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "build": "vite build",
    "build:next": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "preview": "vite preview",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",

    "prepare": "svelte-kit sync || echo ''",

    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "cms": "cross-env PAYLOAD_CONFIG_PATH=./app/cms/payload.config.ts next dev app/cms -p 3000",

    "lint": "eslint .",
    "format": "prettier --write .",

    "test": "pnpm run test:int && pnpm run test:e2e",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --import=tsx/esm\" playwright test --config=playwright.config.ts",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.84.0",
    "@payloadcms/next": "^3.84.0",
    "@payloadcms/richtext-lexical": "^3.84.0",
    "@payloadcms/ui": "3.84.0",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "next": "^16.2.4",
    "payload": "^3.84.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.9",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.5.2",
    "eslint": "^9.16.0",
    "eslint-config-next": "16.2.3",
    "jsdom": "28.0.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "tsx": "4.21.0",
    "typescript": "5.7.3",
    "vite": "^8.0.7",
    "vite-tsconfig-paths": "6.0.5",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}